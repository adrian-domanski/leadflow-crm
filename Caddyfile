leadcrm.kodario.com, www.leadcrm.kodario.com {

    handle /api/* {
        reverse_proxy leadcrm_backend:8000 {
            header_up X-Forwarded-Proto https
        }
    }

    handle {
        reverse_proxy leadcrm_frontend:3000
    }
}

shop.kodario.com, www.shop.kodario.com {

    handle /api/* {
        reverse_proxy store_backend:8000 {
            header_up X-Forwarded-Proto https
        }
    }

    handle {
        root * /srv/store
        file_server
        try_files {path} /index.html
    }

    @static path /static/*
        handle @static {
        root * /app/staticfiles
        file_server
    }

    @media path /media/*
        handle @media {
        root * /app/media
        file_server
    }
    
}